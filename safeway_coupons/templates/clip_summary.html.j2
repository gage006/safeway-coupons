{#- Macro: shared offer card body (name link, description, expiry/category) -#}
{% macro offer_body(offer) -%}
<a href="{{ offer.offer_details_url }}" class="offer-link"
   style="font-family:Arial,sans-serif;font-size:13px;font-weight:bold;color:#1a1a1a;text-decoration:none">
<span style="display:inline-block;background-color:#c8102e;color:#fff;font-family:Arial,sans-serif;font-size:11px;font-weight:bold;padding:1px 6px;border-radius:2px;margin-right:4px;vertical-align:middle">{{ offer.offer_price }}</span>{{ offer.name }}</a>
<div style="font-family:Arial,sans-serif;font-size:12px;color:#555;margin-top:3px" class="muted">{{ offer.description }}</div>
<div style="font-family:Arial,sans-serif;font-size:11px;color:#999;margin-top:2px" class="muted">
Exp {{ offer.end_date.day }} {{ offer.end_date.strftime('%b %Y') -}}
{% if offer.category %} &nbsp;·&nbsp; {{ offer.category }}
{%- elif offer.category_type %} &nbsp;·&nbsp; {{ offer.category_type }}{% endif %}
</div>
{%- endmacro %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light dark">
<meta name="supported-color-schemes" content="light dark">
<style>
@media(prefers-color-scheme:dark){
.wrap{background-color:#1a1a1a!important}
.card{background-color:#2d2d2d!important;color:#e0e0e0!important}
.dim{background-color:#252525!important}
.muted{color:#aaa!important}
.hdr{background-color:#a00d20!important}
.offer-link{color:#e0e0e0!important}
}
@media(max-width:480px){
.thumb{display:block!important;width:100%!important;text-align:center!important;padding:8px 8px 0 8px!important}
.detail{display:block!important;width:100%!important;padding:6px 8px 8px 8px!important}
}
</style>
</head>
<body style="margin:0;padding:0;background-color:#f2f2f2" class="wrap">
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
<tr><td align="center" style="padding:16px 8px">
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="max-width:600px">

<!-- Header -->
<tr><td colspan="2" style="background-color:#c8102e;padding:16px;border-radius:6px 6px 0 0" class="hdr">
<div style="font-family:Arial,sans-serif;font-size:18px;font-weight:bold;color:#fff">Safeway for U</div>
<div style="font-family:Arial,sans-serif;font-size:13px;color:#fdd;margin-top:4px">
{{ clipped|length }} coupon{% if clipped|length != 1 %}s{% endif %} clipped for {{ account.username }}
</div>
</td></tr>

<!-- Summary bar -->
<tr><td colspan="2" style="background-color:#fff;padding:8px 16px;border-bottom:2px solid #f0f0f0" class="card">
<span style="font-family:Arial,sans-serif;font-size:12px;color:#777">
{%- for pgm, pgm_offers in by_type.items() -%}
{{ pgm.name }}: {{ pgm_offers|length }}{% if not loop.last %} &nbsp;·&nbsp; {% endif %}
{%- endfor -%}
</span>
</td></tr>

{% if expiring_soon %}
<!-- Expiring-soon notice -->
<tr><td colspan="2" style="background-color:#fff8e1;padding:8px 16px;border-bottom:1px solid #ffe082" class="dim">
<span style="font-family:Arial,sans-serif;font-size:12px;font-weight:bold;color:#7a5000">
&#9888; {{ expiring_soon|length }} coupon{% if expiring_soon|length != 1 %}s{% endif %} expiring within 7&nbsp;days
</span>
</td></tr>
{% for offer in expiring_soon %}
<tr>
<td class="thumb" style="width:68px;padding:8px 4px 8px 8px;vertical-align:top;background-color:#fffde7">
<img src="{{ 'cid:' + offer.offer_id if offer.offer_id in embedded_image_ids else offer.image }}" width="56" height="56" alt="{{ offer.name }}"
     style="display:block;border-radius:3px;border:0">
</td>
<td class="detail" style="padding:8px 8px 8px 0;vertical-align:top;background-color:#fffde7;border-bottom:1px solid #ffe082">
{{ offer_body(offer) }}
</td>
</tr>
{% endfor %}
{% endif %}

<!-- All-offers section heading -->
<tr><td colspan="2" style="background-color:#f8f8f8;padding:8px 16px;border-bottom:1px solid #eee" class="dim">
<span style="font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#888;text-transform:uppercase;letter-spacing:.06em">
{{ section_label -}}
{% if overflow %} (showing {{ listed_offers|length }} of {{ listed_offers|length + overflow }}){% endif %}
</span>
</td></tr>

<!-- Offer rows -->
{% for offer in listed_offers %}
<tr>
<td class="thumb card" style="width:68px;padding:8px 4px 8px 8px;vertical-align:top;background-color:#fff">
<img src="{{ 'cid:' + offer.offer_id if offer.offer_id in embedded_image_ids else offer.image }}" width="56" height="56" alt="{{ offer.name }}"
     style="display:block;border-radius:3px;border:0">
</td>
<td class="detail card" style="padding:8px 8px 8px 0;vertical-align:top;background-color:#fff;border-bottom:1px solid #f0f0f0">
{{ offer_body(offer) }}
</td>
</tr>
{% endfor %}

{% if overflow %}
<!-- Overflow link -->
<tr><td colspan="2" style="padding:10px 16px;background-color:#fff;font-family:Arial,sans-serif;font-size:12px;text-align:center;border-bottom:1px solid #eee" class="card">
<a href="https://www.safeway.com/foru/coupons-deals.html"
   style="color:#c8102e;text-decoration:none">
View {{ overflow }} more coupon{% if overflow != 1 %}s{% endif %} at Safeway &rarr;
</a>
</td></tr>
{% endif %}

<!-- Footer -->
<tr><td colspan="2" style="padding:12px 16px;background-color:#e8e8e8;border-radius:0 0 6px 6px;font-family:Arial,sans-serif;font-size:11px;color:#999;text-align:center" class="dim">
<a href="https://www.safeway.com/foru/coupons-deals.html"
   style="color:#999;text-decoration:none">View all coupons at Safeway</a>
&nbsp;·&nbsp; {{ account.username }}
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
